DISCORD_TOKEN=           # Our bot's token (from Discord Developer Portal)
COORDLE_CHANNEL_ID=      # Channel ID where !top is posted
COORDLE_BOT_ID=          # Co-ordle bot's user ID (to filter its responses)
STATS_CHANNEL_ID=        # Channel ID where daily summaries are posted (can be same)
